# Finnish translation for Warehouse Picklist for WooCommerce.
msgid ""
msgstr ""
"Project-Id-Version: Warehouse Picklist for WooCommerce 1.0.0\n"
"Report-Msgid-Bugs-To: https://github.com/alhoniko/warehouse-picklist-for-woocommerce/issues\n"
"PO-Revision-Date: 2026-07-03 12:00+0300\n"
"Language: fi\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"X-Domain: warehouse-picklist\n"

msgid "Warehouse Picklist requires WooCommerce to be installed and active."
msgstr "Warehouse Picklist vaatii toimiakseen WooCommerce-lisäosan."

msgid "Warehouse Picklist"
msgstr "Warehouse Picklist"

msgid "Picklist"
msgstr "Keräyslista"

msgid "Saving…"
msgstr "Tallennetaan…"

msgid "Saved."
msgstr "Tallennettu."

msgid "Error saving."
msgstr "Virhe tallennuksessa."

msgid "Select logo"
msgstr "Valitse logo"

msgid "Settings saved."
msgstr "Asetukset tallennettu."

msgid "Settings"
msgstr "Asetukset"

msgid "Category order"
msgstr "Kategoriajärjestys"

msgid "Logo"
msgstr "Logo"

msgid "Remove logo"
msgstr "Poista logo"

msgid "Shown at the top of the printed pick list."
msgstr "Näytetään tulostettavan keräyslistan yläreunassa."

msgid "Business name"
msgstr "Yrityksen nimi"

msgid "Printed as a text logo in the header when no logo image is set. Defaults to the site title."
msgstr "Tulostuu tekstilogona yläreunaan, kun logokuvaa ei ole asetettu. Oletuksena sivuston otsikko."

msgid "Footer note"
msgstr "Alatunnisteteksti"

msgid "Free-form text printed at the bottom of the pick list, e.g. a thank-you note for shipment inserts."
msgstr "Vapaa teksti keräyslistan loppuun, esim. kiitosviesti kun lista lähtee lähetyksen mukana."

msgid "Columns"
msgstr "Sarakkeet"

msgid "Show SKU column"
msgstr "Näytä SKU-sarake"

msgid "Show pick checkboxes"
msgstr "Näytä keräysruudut"

msgid "Package size meta key"
msgstr "Pakkauskoon meta-avain"

msgid "Product meta key for a package size column (ACF field names work). Leave empty to hide the column."
msgstr "Tuotteen meta-avain pakkauskoko-sarakkeelle (ACF-kenttien nimet toimivat sellaisenaan). Jätä tyhjäksi, niin sarake ei näy."

msgid "Save settings"
msgstr "Tallenna asetukset"

msgid "Drag categories into the order you want them to appear on printed pick lists — typically the order you walk your warehouse."
msgstr "Raahaa kategoriat siihen järjestykseen, jossa haluat niiden tulostuvan keräyslistalle — tyypillisesti varastokiertosi mukaan."

msgid "Save order"
msgstr "Tallenna järjestys"

msgid "Reset to default"
msgstr "Palauta oletusjärjestys"

msgid "Print pick list"
msgstr "Tulosta keräyslista"

msgid "You do not have permission to do that."
msgstr "Ei oikeuksia."

msgid "Order not found."
msgstr "Tilausta ei löytynyt."

#. translators: %s: order number
msgid "Pick list — Order #%s"
msgstr "Keräyslista — Tilaus #%s"

msgid "Pick list"
msgstr "Keräyslista"

#. translators: %s: order number
msgid "Order #%s"
msgstr "Tilaus #%s"

msgid "Qty"
msgstr "Määrä"

msgid "Product"
msgstr "Tuote"

msgid "Package"
msgstr "Pakkaus"

msgid "SKU"
msgstr "SKU"

msgid "Print"
msgstr "Tulosta"

msgid "Other"
msgstr "Muut"

msgid "Open picking"
msgstr "Avaa keräily"

#. translators: %s: name of the person who picked the order
msgid "Picked by %s"
msgstr "Kerännyt %s"

msgid "Warehouse Picker"
msgstr "Keräilijä"

msgid "Picking"
msgstr "Keräily"

msgid "No orders waiting to be picked."
msgstr "Ei kerättäviä tilauksia."

#. translators: %s: number of order rows
msgid "Items: %s"
msgstr "Rivejä: %s"

msgid "Picked"
msgstr "Kerätty"

msgid "Missing"
msgstr "Puuttuu"

msgid "Mark as missing"
msgstr "Merkitse puuttuvaksi"

msgid "Mark order as picked"
msgstr "Merkitse tilaus kerätyksi"

msgid "Some rows are not resolved yet. Complete anyway?"
msgstr "Kaikkia rivejä ei ole käsitelty. Merkitäänkö silti valmiiksi?"

#. translators: 1: name, 2: date
msgid "Picking completed by %1$s · %2$s"
msgstr "Keräilyn kuittasi %1$s · %2$s"

msgid "Reopen picking"
msgstr "Avaa keräily uudelleen"

msgid "Back to queue"
msgstr "Takaisin jonoon"

#. translators: %s: order number
msgid "Picking — Order #%s"
msgstr "Keräily — Tilaus #%s"

#. translators: 1: picked row count, 2: total row count
msgid "Picking completed: %1$d of %2$d rows picked"
msgstr "Keräily valmis: %1$d/%2$d riviä kerätty"

#. translators: %s: comma-separated product names
msgid ", missing: %s"
msgstr ", puuttuu: %s"

msgid "Picking reopened."
msgstr "Keräily avattu uudelleen."

msgid "Connection error, try again."
msgstr "Yhteysvirhe, yritä uudelleen."

msgid "✓ = picked · ! = missing item"
msgstr "✓ = kerätty · ! = puuttuva tuote"

msgid "In picking"
msgstr "Keräilyssä"

#. translators: %s: number of orders
msgid "In picking <span class=\"count\">(%s)</span>"
msgid_plural "In picking <span class=\"count\">(%s)</span>"
msgstr[0] "Keräilyssä <span class=\"count\">(%s)</span>"
msgstr[1] "Keräilyssä <span class=\"count\">(%s)</span>"

#. translators: %s: number of orders
msgid "Picked <span class=\"count\">(%s)</span>"
msgid_plural "Picked <span class=\"count\">(%s)</span>"
msgstr[0] "Kerätty <span class=\"count\">(%s)</span>"
msgstr[1] "Kerätty <span class=\"count\">(%s)</span>"

msgid "Order statuses"
msgstr "Tilauksen tilat"

msgid "Update the order status during picking"
msgstr "Päivitä tilauksen tilaa keräilyn aikana"

msgid "Processing → In picking when the first item is picked, → Picked when completed. The customer notification email can be enabled in WooCommerce → Settings → Emails."
msgstr "Käsittelyssä → Keräilyssä kun ensimmäinen rivi kuitataan, → Kerätty kun keräily valmistuu. Asiakkaan sähköposti-ilmoituksen voi kytkeä päälle kohdassa WooCommerce → Asetukset → Sähköpostit."

msgid "Order in picking"
msgstr "Tilaus keräilyssä"

msgid "Sent to the customer when picking of their order starts."
msgstr "Lähetetään asiakkaalle, kun tilauksen keräily alkaa."

msgid "[{site_title}] Your order #{order_number} is being prepared"
msgstr "[{site_title}] Tilaustasi #{order_number} valmistellaan"

msgid "Your order is being prepared"
msgstr "Tilaustasi valmistellaan"

#. translators: %s: customer first name
msgid "Hi %s,"
msgstr "Hei %s,"

msgid "We have started preparing your order at our warehouse. We will notify you when it is on its way."
msgstr "Tilauksesi keräily on aloitettu varastollamme. Ilmoitamme, kun tilaus on matkalla."
